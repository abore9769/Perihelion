# Perihelion mempool API to poll for intents
PERIHELION_MEMPOOL_URL=http://localhost:8080

# This solver's EVM address (claims intents reserved via preferredSolver)
PERIHELION_SOLVER_ADDRESS=0x0000000000000000000000000000000000000000

# Minimum profit margin required to fill, in basis points of the source amount
PERIHELION_MIN_MARGIN_BPS=15

# Mempool poll interval, milliseconds
PERIHELION_POLL_INTERVAL_MS=2000

# Comma-separated Stellar assets this solver provides liquidity for
# Format: "native" for XLM, or "<CODE>:<ISSUER>" for issued assets
PERIHELION_SUPPORTED_ASSETS=native,USDC:GA5ZSEJYB37JRC5AVCIA5MOP4RHTM335X2KGX3IHOJAPP5RE34K4KZVN
