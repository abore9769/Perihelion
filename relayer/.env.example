# EVM source chain RPC
PERIHELION_EVM_RPC_URL=http://localhost:8545

# Stellar RPC / Horizon
PERIHELION_STELLAR_RPC_URL=https://soroban-testnet.stellar.org

# EVM escrow contract that emits bridge messages
PERIHELION_ESCROW_ADDRESS=

# Soroban settlement (LayerZero OApp) contract id
PERIHELION_SETTLEMENT_CONTRACT=

# Block confirmations to wait before relaying a source message
PERIHELION_CONFIRMATIONS=6

# Poll interval for new messages, milliseconds
PERIHELION_POLL_INTERVAL_MS=5000
